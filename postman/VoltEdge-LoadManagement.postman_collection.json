{
  "info": {
    "_postman_id": "voltedge-load-mgmt-0001",
    "name": "VoltEdge — Load Management Demo",
    "description": "End-to-end demo of the Load Control Service + Analytics API.\n\nRun top to bottom against a freshly started stack (`docker compose up`) to reproduce the report scenario for LoadArea YN: baseline ~231 kW (WARNING) -> a new 11 kW session pushes load to 242 kW (CRITICAL) -> automatic 10% regulation -> ~217.8 kW (stabilized). Each request includes test assertions.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "area_code",
      "value": "YN"
    },
    {
      "key": "charger_id",
      "value": "YN-22"
    },
    {
      "key": "sessionId",
      "value": ""
    },
    {
      "key": "baselineLoad",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Setup — health & info",
      "item": [
        {
          "name": "1. Health check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('database up', () => pm.expect(pm.response.json().database).to.eql('up'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/health"
          }
        },
        {
          "name": "2. Service info",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/"
          }
        }
      ]
    },
    {
      "name": "2. Onboarding — kunden registrerer sit område",
      "description": "Kunden onboarder fra en HELT TOM database, udelukkende via API'et: registrér load area YN, registrér dens 24 ladestandere, og start baseline-opladningerne (231 kW). Alt sker med rigtige Postman-kald — intet eksternt script. Kør mod en tom DB.",
      "item": [
        {
          "name": "1. Registrér load area YN",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('oprettet (201) eller findes (409)', () => pm.expect(pm.response.code).to.be.oneOf([201,409]));",
                  "if (pm.response.code === 201) console.log('Område YN oprettet (240 kW).'); else console.log('Område YN findes allerede.');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/load-areas",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"areaCode\": \"YN\",\n  \"areaName\": \"Ydre Nørrebro\",\n  \"maxCapacityKw\": 240\n}"
            }
          }
        },
        {
          "name": "2. Se registrerede områder",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('YN er registreret', () => pm.expect(pm.response.json().map(a => a.areaCode)).to.include('YN'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/load-areas"
          }
        },
        {
          "name": "3. Registrér de 24 ladestandere",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Registrér de 24 ladestandere (YN-01..YN-24) via rigtige API-kald — sekventielt.",
                  "const base = pm.variables.get('base_url');",
                  "const area = pm.variables.get('area_code');",
                  "const ids = [];",
                  "for (let g = 1; g <= 24; g++) ids.push('YN-' + String(g).padStart(2, '0'));",
                  "function register(i) {",
                  "  if (i >= ids.length) return;",
                  "  pm.sendRequest({",
                  "    url: base + '/load-areas/' + area + '/chargers',",
                  "    method: 'POST',",
                  "    header: { 'Content-Type': 'application/json' },",
                  "    body: { mode: 'raw', raw: JSON.stringify({ chargerId: ids[i], maxPowerKw: 11 }) }",
                  "  }, function (err, res) { register(i + 1); });",
                  "}",
                  "register(0);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('alle 24 ladestandere er registreret', () => pm.expect(pm.response.json().length).to.eql(24));",
                  "console.log('Registrerede ladestandere: ' + pm.response.json().length);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/load-areas/{{area_code}}/chargers",
            "description": "Pre-request-scriptet registrerer YN-01..YN-24 sekventielt via API'et; selve requesten henter listen bagefter."
          }
        },
        {
          "name": "4. Start baseline-opladninger (→ 231 kW)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Start baseline-opladninger: 21 x 11 kW = 231 kW (WARNING). YN-22/23/24 frie.",
                  "const base = pm.variables.get('base_url');",
                  "const area = pm.variables.get('area_code');",
                  "const sessions = [];",
                  "for (let g = 1; g <= 21; g++) sessions.push({ chargerId: 'YN-' + String(g).padStart(2, '0'), powerLevelKw: 11 });",
                  "function start(i) {",
                  "  if (i >= sessions.length) return;",
                  "  pm.sendRequest({",
                  "    url: base + '/load-areas/' + area + '/sessions',",
                  "    method: 'POST',",
                  "    header: { 'Content-Type': 'application/json' },",
                  "    body: { mode: 'raw', raw: JSON.stringify(sessions[i]) }",
                  "  }, function (err, res) { start(i + 1); });",
                  "}",
                  "start(0);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const a = pm.response.json();",
                  "pm.test('baseline ~231 kW', () => pm.expect(a.currentLoadKw).to.be.within(229, 233));",
                  "pm.test('status WARNING', () => pm.expect(a.status).to.eql('WARNING'));",
                  "console.log(`Baseline: ${a.currentLoadKw} kW (${a.status}), ${a.activeSessionCount} sessioner. Ledige: YN-22, YN-23, YN-24.`);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/load-areas/{{area_code}}/status",
            "description": "Pre-request-scriptet starter 21 baseline-sessioner; selve requesten henter status bagefter."
          }
        },
        {
          "name": "5. Se én laders status (YN-01)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const ch = pm.response.json();",
                  "pm.test('har navn + status-felter', () => { ['name','occupancyStatus','connectivity','currentOutputKw'].forEach(k => pm.expect(ch).to.have.property(k)); });",
                  "console.log(`${ch.chargerId} (${ch.name}): ${ch.occupancyStatus}, ${ch.connectivity}, ${ch.currentOutputKw} kW`);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/load-areas/{{area_code}}/chargers/YN-01"
          }
        },
        {
          "name": "6. Charger heartbeat (YN-01 melder sig online)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('laderen er ONLINE', () => pm.expect(pm.response.json().connectivity).to.eql('ONLINE'));",
                  "console.log('Heartbeat OK — YN-01 er ONLINE');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/load-areas/{{area_code}}/chargers/YN-01/heartbeat"
          }
        }
      ]
    },
    {
      "name": "3. Regulering — ledig lader rammer max",
      "item": [
        {
          "name": "1. Ladere i området (præcis 24 standere)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const ch = pm.response.json();",
                  "pm.test('omraadet har 24 standere (ingen nye registreres)', () => pm.expect(ch.length).to.eql(24));",
                  "const free = ch.filter(c => c.status === 'AVAILABLE').map(c => c.chargerId);",
                  "console.log('Ledige standere: ' + (free.join(', ') || 'ingen'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/load-areas/{{area_code}}/chargers"
          }
        },
        {
          "name": "2. Aktuel status (baseline ~231 kW, WARNING)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const a = pm.response.json();",
                  "console.log(`Baseline: ${a.currentLoadKw} kW / ${a.maxCapacityKw} kW (${a.status})`);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/load-areas/{{area_code}}/status"
          }
        },
        {
          "name": "3. Ledig lader YN-22 tages i brug (rammer max -> regulering)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Kanonisk forloeb mod frisk seed: 231 + 11 = 242 kW (CRITICAL) -> 10% regulering -> 217,8 kW.",
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const r = pm.response.json();",
                  "const a = r.areaStatus;",
                  "pm.collectionVariables.set('sessionId', r.sessionId);",
                  "pm.test('regulering holder omraadet paa/under max', () => pm.expect(a.currentLoadKw).to.be.at.most(a.maxCapacityKw + 0.001));",
                  "console.log(`Lader ${pm.collectionVariables.get('charger_id')} startet; omraadet er nu ${a.currentLoadKw} kW (${a.status})`);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/load-areas/{{area_code}}/sessions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"chargerId\": \"{{charger_id}}\",\n  \"powerLevelKw\": 11\n}"
            }
          }
        },
        {
          "name": "4. Regulation events (vises nu i BI)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const ev = pm.response.json();",
                  "pm.test('regulering blev registreret', () => pm.expect(ev.length).to.be.above(0));",
                  "console.log('Regulation events i BI: ' + ev.map(e => e.eventType).join(', '));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/analytics/{{area_code}}/regulation-events?limit=20"
          }
        },
        {
          "name": "5. Load adjustments (effekt-reduktioner)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const adj = pm.response.json();",
                  "pm.test('effekt blev reduceret', () => pm.expect(adj.length).to.be.above(0));",
                  "console.log('Antal load adjustments: ' + adj.length);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/load-areas/{{area_code}}/adjustments?limit=50"
          }
        },
        {
          "name": "6. Status (stabiliseret ~217,8 kW)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const a = pm.response.json();",
                  "console.log(`Slutstatus: ${a.currentLoadKw} kW / ${a.maxCapacityKw} kW (${a.status})`);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/load-areas/{{area_code}}/status"
          }
        }
      ],
      "description": "Forudsætning: baseline er bygget op (kør Onboarding-mappen først). Tager den ledige lader YN-22 i brug -> 242 kW CRITICAL -> 10% regulering -> 217,8 kW."
    },
    {
      "name": "4. Analytics (BI)",
      "item": [
        {
          "name": "KPIs",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/analytics/{{area_code}}/kpis"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const k = pm.response.json();",
                  "pm.test('has utilisation', () => pm.expect(k).to.have.property('currentUtilisationPct'));",
                  "console.log(`Utilisation ${k.currentUtilisationPct}% | adjustments ${k.totalAdjustments} | open interventions ${k.openInterventions}`);"
                ]
              }
            }
          ]
        },
        {
          "name": "Load timeseries (24h)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/analytics/{{area_code}}/load-timeseries?hours=24"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns samples', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Daily peaks (7d)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/analytics/{{area_code}}/daily-peaks?days=7"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns days', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Status distribution (7d)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/analytics/{{area_code}}/status-distribution?days=7"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns distribution', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Regulation events (diagnostic)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/analytics/{{area_code}}/regulation-events?limit=20"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns events', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "console.log(`Regulation events: ${pm.response.json().map(e => e.eventType).join(', ')}`);"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
