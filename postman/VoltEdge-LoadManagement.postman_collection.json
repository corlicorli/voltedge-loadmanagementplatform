{
  "info": {
    "_postman_id": "voltedge-load-mgmt-0001",
    "name": "VoltEdge — Load Management Demo",
    "description": "End-to-end demo of the Load Control Service + Analytics API.\n\nRun top to bottom against a freshly started stack (`docker compose up`) to reproduce the report scenario for LoadArea YN: baseline ~233 kW (WARNING) -> a new 11 kW session pushes load to 244 kW (CRITICAL) -> automatic 10% regulation -> ~219.6 kW (stabilized). Each request includes test assertions.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "area_code",
      "value": "YN"
    },
    {
      "key": "charger_id",
      "value": "YN-23"
    },
    {
      "key": "sessionId",
      "value": ""
    },
    {
      "key": "baselineLoad",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Setup — health & info",
      "item": [
        {
          "name": "1. Health check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('database up', () => pm.expect(pm.response.json().database).to.eql('up'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/health"
          }
        },
        {
          "name": "2. Service info",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/"
          }
        }
      ]
    },
    {
      "name": "2. Onboarding — kunden registrerer sit område",
      "description": "Viser hvordan en kunde onboarder fra en HELT TOM database: registrér load area YN og dens ladestandere via API'et. Ren registrering (ingen last endnu). For alle 24 standere + baseline-last på ~233 kW, kør populatoren: docker compose exec backend python scripts/populate_demo.py",
      "item": [
        {
          "name": "1. Registrér load area YN",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('oprettet (201) eller findes (409)', () => pm.expect(pm.response.code).to.be.oneOf([201,409]));",
                  "if (pm.response.code === 201) { const a = pm.response.json(); console.log(`Område ${a.areaCode} oprettet: ${a.maxCapacityKw} kW, status ${a.status}`); }",
                  "else { console.log('Område YN findes allerede.'); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/load-areas",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"areaCode\": \"YN\",\n  \"areaName\": \"Ydre Nørrebro\",\n  \"maxCapacityKw\": 240\n}"
            }
          }
        },
        {
          "name": "2. Se registrerede områder",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('YN er registreret', () => pm.expect(pm.response.json().map(a => a.areaCode)).to.include('YN'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/load-areas"
          }
        },
        {
          "name": "3. Registrér ladestander YN-01",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('oprettet (201) eller findes (422)', () => pm.expect(pm.response.code).to.be.oneOf([201,422]));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/load-areas/{{area_code}}/chargers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"chargerId\": \"YN-01\",\n  \"maxPowerKw\": 11\n}"
            }
          }
        },
        {
          "name": "4. Registrér ladestander YN-02",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('oprettet (201) eller findes (422)', () => pm.expect(pm.response.code).to.be.oneOf([201,422]));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/load-areas/{{area_code}}/chargers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"chargerId\": \"YN-02\",\n  \"maxPowerKw\": 11\n}"
            }
          }
        },
        {
          "name": "5. Se områdets ladestandere",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const ids = pm.response.json().map(c => c.chargerId);",
                  "pm.test('YN-01 er registreret', () => pm.expect(ids).to.include('YN-01'));",
                  "console.log('Registrerede standere: ' + ids.length);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/load-areas/{{area_code}}/chargers"
          }
        }
      ]
    },
    {
      "name": "3. Regulering — ledig lader rammer max",
      "item": [
        {
          "name": "1. Ladere i området (præcis 24 standere)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const ch = pm.response.json();",
                  "pm.test('omraadet har 24 standere (ingen nye registreres)', () => pm.expect(ch.length).to.eql(24));",
                  "const free = ch.filter(c => c.status === 'AVAILABLE').map(c => c.chargerId);",
                  "console.log('Ledige standere: ' + (free.join(', ') || 'ingen'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/load-areas/{{area_code}}/chargers"
          }
        },
        {
          "name": "2. Aktuel status (baseline ~233 kW, WARNING)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const a = pm.response.json();",
                  "console.log(`Baseline: ${a.currentLoadKw} kW / ${a.maxCapacityKw} kW (${a.status})`);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/load-areas/{{area_code}}/status"
          }
        },
        {
          "name": "3. Ledig lader YN-23 tages i brug (rammer max -> regulering)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Kanonisk forloeb mod frisk seed: 233 + 11 = 244 kW (CRITICAL) -> 10% regulering -> 219,6 kW.",
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const r = pm.response.json();",
                  "const a = r.areaStatus;",
                  "pm.collectionVariables.set('sessionId', r.sessionId);",
                  "pm.test('regulering holder omraadet paa/under max', () => pm.expect(a.currentLoadKw).to.be.at.most(a.maxCapacityKw + 0.001));",
                  "console.log(`Lader ${pm.collectionVariables.get('charger_id')} startet; omraadet er nu ${a.currentLoadKw} kW (${a.status})`);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/load-areas/{{area_code}}/sessions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"chargerId\": \"{{charger_id}}\",\n  \"powerLevelKw\": 11\n}"
            }
          }
        },
        {
          "name": "4. Regulation events (vises nu i BI)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const ev = pm.response.json();",
                  "pm.test('regulering blev registreret', () => pm.expect(ev.length).to.be.above(0));",
                  "console.log('Regulation events i BI: ' + ev.map(e => e.eventType).join(', '));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/analytics/{{area_code}}/regulation-events?limit=20"
          }
        },
        {
          "name": "5. Load adjustments (effekt-reduktioner)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const adj = pm.response.json();",
                  "pm.test('effekt blev reduceret', () => pm.expect(adj.length).to.be.above(0));",
                  "console.log('Antal load adjustments: ' + adj.length);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/load-areas/{{area_code}}/adjustments?limit=50"
          }
        },
        {
          "name": "6. Status (stabiliseret ~219,6 kW)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const a = pm.response.json();",
                  "console.log(`Slutstatus: ${a.currentLoadKw} kW / ${a.maxCapacityKw} kW (${a.status})`);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/load-areas/{{area_code}}/status"
          }
        }
      ],
      "description": "Forudsætning: baseline er bygget op (kør Onboarding + populatoren: docker compose exec backend python scripts/populate_demo.py). Tager den ledige lader YN-23 i brug -> 244 kW CRITICAL -> 10% regulering -> 219,6 kW."
    },
    {
      "name": "4. Analytics (BI)",
      "item": [
        {
          "name": "KPIs",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/analytics/{{area_code}}/kpis"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const k = pm.response.json();",
                  "pm.test('has utilisation', () => pm.expect(k).to.have.property('currentUtilisationPct'));",
                  "console.log(`Utilisation ${k.currentUtilisationPct}% | adjustments ${k.totalAdjustments} | open interventions ${k.openInterventions}`);"
                ]
              }
            }
          ]
        },
        {
          "name": "Load timeseries (24h)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/analytics/{{area_code}}/load-timeseries?hours=24"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns samples', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Daily peaks (7d)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/analytics/{{area_code}}/daily-peaks?days=7"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns days', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Status distribution (7d)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/analytics/{{area_code}}/status-distribution?days=7"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns distribution', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Regulation events (diagnostic)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/analytics/{{area_code}}/regulation-events?limit=20"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns events', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "console.log(`Regulation events: ${pm.response.json().map(e => e.eventType).join(', ')}`);"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
