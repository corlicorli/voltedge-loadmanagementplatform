# VoltEdge Load Control Service — environment configuration.
# Copy to .env and fill in your own values. NEVER commit a real .env file.

APP_ENV=development
LOG_LEVEL=INFO

# --- MongoDB ---------------------------------------------------------------
# Local development (docker compose provides a mongo:7 container on port 27017):
MONGO_URL=mongodb://localhost:27017
#
# MongoDB Atlas (cloud service) — create the free cluster yourself, then paste
# the connection string here. Keep your credentials out of git.
# MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=voltedge
