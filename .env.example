# ---------------------------------------------------------------------------
# VoltEdge Load Management — environment template
# Copy to .env (docker compose reads it automatically). Defaults are dev-safe.
# ---------------------------------------------------------------------------

# PostgreSQL (operational database + analytics warehouse views)
POSTGRES_USER=voltedge
POSTGRES_PASSWORD=voltedge
POSTGRES_DB=voltedge
POSTGRES_PORT=5432

# Load Control Service (FastAPI backend)
APP_ENV=development
LOG_LEVEL=INFO
# DATABASE_URL uses the docker-compose service name "postgres" as host
DATABASE_URL=postgresql://voltedge:voltedge@postgres:5432/voltedge
RUN_MIGRATIONS_ON_STARTUP=true
SEED_ON_STARTUP=true

# React BI dashboard (build-time API base URL)
VITE_API_BASE_URL=http://localhost:8000

# Grafana (operational/API monitoring — separate from the BI dashboard)
# Host port 3001 by default (3000 is often used by other local dev tools).
GRAFANA_PORT=3001
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
