# ---------------------------------------------------------------------------
# VoltEdge Load Management — environment template
# Copy to .env (docker compose reads it automatically). Defaults are dev-safe.
# NEVER commit a real .env (it is git-ignored).
# ---------------------------------------------------------------------------

# MongoDB (operational database + analytics store)
MONGO_PORT=27017
MONGO_EXPRESS_PORT=8081

# Load Control Service (FastAPI backend)
APP_ENV=development
LOG_LEVEL=INFO
# MONGO_URL uses the docker-compose service name "mongo" as host. For MongoDB
# Atlas (cloud), set it to your SRV string instead, e.g.:
#   MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb://mongo:27017
MONGO_DB=voltedge

# React BI dashboard (build-time API base URL)
VITE_API_BASE_URL=http://localhost:8000

# Grafana (operational/API monitoring — separate from the BI dashboard)
# Host port 3001 by default (3000 is often used by other local dev tools).
GRAFANA_PORT=3001
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
